{{!
    Course Insights dashboard — stat cards, chart, course insight cards, and pagination.

    @template local_courseinsights/dashboard

    Context variables required for this template:
    * hasexport {bool} Whether to show the CSV export button.
    * exporturl {string} URL for the CSV export (unescaped).
    * exportlabel {string} Label for the export button.
    * haschart {bool} Whether to render the chart section.
    * chart {string} Rendered Moodle chart HTML (unescaped).
    * charttruncated {bool} Whether the chart shows a subset of courses.
    * charttruncatenote {string} Note explaining the chart truncation.
    * hasrecords {bool} Whether the query returned any rows.
    * emptystate {string} Message shown when there are no rows.
    * totalcourses {number} Total course count across all pages.
    * statenrolled {number} Total enrolled students.
    * statsubmissions {number} Total assignment submissions.
    * statattempts {number} Total quiz/exam attempts.
    * showstatsubmissions {bool} Whether to show the submissions stat card.
    * showstatattempts {bool} Whether to show the attempts stat card.
    * label_statcourses {string} Label for the courses stat card.
    * label_statenrolled {string} Label for the students stat card.
    * label_statsubmissions {string} Label for the submissions stat card.
    * label_statattempts {string} Label for the attempts stat card.
    * hascoursecards {bool} Whether to show course insight cards.
    * courseinsightslabel {string} Section heading above the course cards.
    * completionratelabel {string} Label for the completion rate progress bar.
    * coursecards {array} Course insight cards; each item has:
    *     coursename {string}, isactive {bool}, statuslabel {string},
    *     healthgrade {string}, healthgradeclass {string}, healthscoretooltip {string},
    *     completionratedisplay {string}, completionratewidth {string},
    *     meta {array} — four items each with label and value strings.
    * haspagination {bool} Whether to show pagination controls.
    * pagination_info {string} "Showing X to Y of Z courses" text.
    * hasprev {bool} Whether there is a previous page.
    * hasnext {bool} Whether there is a next page.
    * prevpage {number} 0-based index of the previous page.
    * nextpage {number} 0-based index of the next page.
    * pages {array} Page items: num, label, active, isellipsis.

    Example context (json):
    {
        "hasexport": true,
        "exporturl": "/local/courseinsights/export.php",
        "exportlabel": "Export CSV",
        "haschart": true,
        "chart": "<div>...</div>",
        "charttruncated": false,
        "charttruncatenote": "Chart shows the first 20 courses.",
        "hasrecords": true,
        "emptystate": "No courses found.",
        "totalcourses": 1,
        "statenrolled": 101,
        "statsubmissions": 1,
        "statattempts": 0,
        "showstatsubmissions": true,
        "showstatattempts": true,
        "label_statcourses": "Courses",
        "label_statenrolled": "Students",
        "label_statsubmissions": "Submissions",
        "label_statattempts": "Attempts",
        "hascoursecards": true,
        "courseinsightslabel": "Course Insights",
        "completionratelabel": "Completion rate %",
        "coursecards": [
            {
                "coursename": "Web Development",
                "isactive": true,
                "statuslabel": "Active",
                "completionratedisplay": "0%",
                "completionratewidth": "0%",
                "meta": [
                    {"label": "Enrolled students", "value": "101"},
                    {"label": "Teachers", "value": "Admin User"},
                    {"label": "Assignments", "value": "11"},
                    {"label": "Last student activity", "value": "20 June 2026"}
                ]
            }
        ],
        "haspagination": false,
        "pagination_info": "Showing 1 to 1 of 1 courses",
        "hasprev": false,
        "hasnext": false,
        "prevpage": 0,
        "nextpage": 0,
        "pages": [{"num": 0, "label": "1", "active": true, "isellipsis": false}]
    }
}}
<div class="local-courseinsights-dashboard">

    {{#hasexport}}
    <div class="ci-export">
        <a href="{{{exporturl}}}" class="ci-btn-ghost">{{exportlabel}}</a>
        <a href="{{{exportxlsxurl}}}" class="ci-btn-ghost">{{exportxlsxlabel}}</a>
        <button type="button" class="ci-btn-ghost ci-btn-print" onclick="window.print()">{{#str}} printreport, local_courseinsights {{/str}}</button>
    </div>
    {{/hasexport}}

    {{#hasrecords}}
    <div class="ci-overview-label">
        <span class="ci-overview-pill">{{#str}} dashboardoverview, local_courseinsights {{/str}}</span>
    </div>
    <div class="ci-stats-grid">
        <div class="ci-stat-card">
            <span class="ci-stat-label">{{label_statcourses}}</span>
            <span class="ci-stat-value ci-stat-value--primary">{{totalcourses}}</span>
        </div>
        <div class="ci-stat-card">
            <span class="ci-stat-label">{{label_statenrolled}}</span>
            <span class="ci-stat-value ci-stat-value--secondary">{{statenrolled}}</span>
        </div>
        {{#showstatsubmissions}}
        <div class="ci-stat-card">
            <span class="ci-stat-label">{{label_statsubmissions}}</span>
            <span class="ci-stat-value ci-stat-value--tertiary">{{statsubmissions}}</span>
            {{#hascompare}}{{#deltasubmissions}}
            <div class="ci-compare-row">
                <span class="ci-compare-vs">vs {{comparevalue}}</span>
                {{#isup}}<span class="ci-delta ci-delta--up">&#x2191;{{pct}}%</span>{{/isup}}
                {{#isdown}}<span class="ci-delta ci-delta--down">&#x2193;{{pct}}%</span>{{/isdown}}
                {{#isneutral}}<span class="ci-delta ci-delta--neutral">&mdash;</span>{{/isneutral}}
            </div>
            {{/deltasubmissions}}{{/hascompare}}
        </div>
        {{/showstatsubmissions}}
        {{#showstatattempts}}
        <div class="ci-stat-card">
            <span class="ci-stat-label">{{label_statattempts}}</span>
            <span class="ci-stat-value">{{statattempts}}</span>
            {{#hascompare}}{{#deltaattempts}}
            <div class="ci-compare-row">
                <span class="ci-compare-vs">vs {{comparevalue}}</span>
                {{#isup}}<span class="ci-delta ci-delta--up">&#x2191;{{pct}}%</span>{{/isup}}
                {{#isdown}}<span class="ci-delta ci-delta--down">&#x2193;{{pct}}%</span>{{/isdown}}
                {{#isneutral}}<span class="ci-delta ci-delta--neutral">&mdash;</span>{{/isneutral}}
            </div>
            {{/deltaattempts}}{{/hascompare}}
        </div>
        {{/showstatattempts}}
    </div>
    {{/hasrecords}}

    {{#haschart}}
    <div class="ci-chart-card">
        <h3 class="ci-chart-title">{{#str}} activityoverview, local_courseinsights {{/str}}</h3>
        <div class="ci-chart-inner">
            {{{chart}}}
        </div>
        {{#charttruncated}}
        <p class="ci-chart-note">{{charttruncatenote}}</p>
        {{/charttruncated}}
    </div>
    {{/haschart}}

    {{#hascoursecards}}
    <div class="ci-cards-section">
        <h3 class="ci-section-title">{{courseinsightslabel}}</h3>
        <div class="ci-cards-grid">
        {{#coursecards}}
        <div class="ci-course-card">
            <div class="ci-course-card__inner">
                <div class="ci-course-card__header">
                    <div class="ci-course-card__header-text">
                        <h4 class="ci-course-card__title">{{coursename}}</h4>
                        {{#haslastactivity}}<p class="ci-course-card__subtitle">{{lastactivitysubtitle}}</p>{{/haslastactivity}}
                    </div>
                    <div class="ci-course-card__badges">
                        <span class="ci-health-badge {{healthgradeclass}}" title="{{healthscoretooltip}}">{{healthgrade}}</span>
                        <span class="ci-badge {{#isactive}}ci-badge--active{{/isactive}}{{^isactive}}ci-badge--inactive{{/isactive}}">{{statuslabel}}</span>
                    </div>
                </div>
                <div class="ci-progress-wrap">
                    <div class="ci-progress-header">
                        <span class="ci-progress-label">{{completionratelabel}}</span>
                        <span class="ci-progress-pct">{{completionratedisplay}}</span>
                    </div>
                    <div class="ci-progress-bar">
                        <div class="ci-progress-bar__fill" style="width: {{completionratewidth}}"></div>
                    </div>
                </div>
                <div class="ci-course-meta">
                    {{#meta}}
                    <div class="ci-meta-item">
                        <span class="ci-meta-label">{{label}}</span>
                        <span class="ci-meta-value">{{value}}</span>
                    </div>
                    {{/meta}}
                </div>
            </div>
            <a href="{{{detailurl}}}" class="ci-course-card__footer">{{detailedreportlabel}}</a>
        </div>
        {{/coursecards}}
        </div>
    </div>
    {{/hascoursecards}}

    {{#pagination_info}}
    <p class="ci-pagination-summary text-muted"><small>{{pagination_info}}</small></p>
    {{/pagination_info}}

    {{#haspagination}}
    <nav class="local-courseinsights-pagination mt-3" aria-label="Page navigation">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <small class="text-muted">{{pagination_info}}</small>
            <ul class="pagination pagination-sm mb-0">
                {{#hasprev}}
                <li class="page-item">
                    <button type="button" class="page-link" data-ci-page="{{prevpage}}" aria-label="Previous">&laquo;</button>
                </li>
                {{/hasprev}}
                {{^hasprev}}
                <li class="page-item disabled" aria-hidden="true"><span class="page-link">&laquo;</span></li>
                {{/hasprev}}
                {{#pages}}
                {{#isellipsis}}
                <li class="page-item disabled" aria-hidden="true"><span class="page-link">{{label}}</span></li>
                {{/isellipsis}}
                {{^isellipsis}}
                {{#active}}
                <li class="page-item active" aria-current="page"><span class="page-link">{{label}}</span></li>
                {{/active}}
                {{^active}}
                <li class="page-item"><button type="button" class="page-link" data-ci-page="{{num}}">{{label}}</button></li>
                {{/active}}
                {{/isellipsis}}
                {{/pages}}
                {{#hasnext}}
                <li class="page-item">
                    <button type="button" class="page-link" data-ci-page="{{nextpage}}" aria-label="Next">&raquo;</button>
                </li>
                {{/hasnext}}
                {{^hasnext}}
                <li class="page-item disabled" aria-hidden="true"><span class="page-link">&raquo;</span></li>
                {{/hasnext}}
            </ul>
        </div>
    </nav>
    {{/haspagination}}

    {{^hasrecords}}
    <div class="ci-empty">
        <p>{{emptystate}}</p>
    </div>
    {{/hasrecords}}

</div>
